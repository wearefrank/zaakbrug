<Module xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../FrankConfig.xsd">
    <Adapter name="Zaken_PostZgwzaak_bijwerken"
        active="${Zaken_PostZgwzaak_bijwerken.Active}"
        description="">

        <Receiver name="Zaken_PostZgwzaak_bijwerken">
            <JavaListener name="Zaken_PostZgwzaak_bijwerken" returnedSessionKeys="Error" />
        </Receiver>

        <Pipeline>
            <Exits>
                <Exit name="EXIT" state="SUCCESS"/>
                <Exit name="EXCEPTION" state="ERROR"/>
            </Exits>

            <SenderPipe
                name="GetAuthorizationHeaderForZakenApi"
                getInputFromFixedValue="&lt;dummy/&gt;"
                >
                <IbisLocalSender
                    name="GetAuthorizationHeaderForZakenApiSender"
                    javaListener="GenerateAuthorizationHeaderForZakenApi"
                    returnedSessionKeys="Error,Authorization"
                    >
                </IbisLocalSender>
                <Forward name="success" path="DeleteRol" />
                <Forward name="exception" path="EXCEPTION" />
            </SenderPipe>
            <!-- InitiatorUUID -->

            <SenderPipe
                name="DeleteRol">
                <HttpSender
                    name="DeleteRolSender" 
                    methodType="DELETE"
                    headersParams="Authorization,Accept-Crs"
                    timeout="${zaakbrug.zgw.zaken-api.timeout}"
                    verifyHostname="${zaakbrug.zgw.zaken-api.verifyHostname}"
                    allowSelfSignedCertificates="${zaakbrug.zgw.zaken-api.allowSelfSignedCertificates}"
                    disableCookies="${zaakbrug.zgw.zaken-api.disableCookies}"
                    ignoreCertificateExpiredException="${zaakbrug.zgw.zaken-api.ignoreCertificateExpiredException}"
                    truststore="${zaakbrug.zgw.zaken-api.truststore.uri}"
                    truststoreAuthAlias="${zaakbrug.zgw.zaken-api.truststore.authAlias}"
                    truststoreType="${zaakbrug.zgw.zaken-api.truststore.type}">
                    <Param name="url" sessionKey="InitiatorUUID"/>
                    <Param name="Accept-Crs" value="EPSG:4326"/>
                    <Param name="Authorization"  sessionKey="Authorization" />
                </HttpSender>
                <Forward name="success" path="PostZgwzaak_bijwerken"/>
                <Forward name="exception" path="ErrorJsonToXml" />
            </SenderPipe>

            <SenderPipe
                name="PostZgwzaak_bijwerken"
                storeResultInSessionKey="PostZgwzaak_bijwerkenResult"
                getInputFromSessionKey="originalMessage"
                >

				<HttpSender
					name="PostZgwzaak_bijwerkenSender"
					methodType="POST"
					headersParams="Authorization,Accept-Crs,Content-Crs"
                    contentType="application/json"
                    timeout="${zaakbrug.zgw.zaken-api.timeout}"
                    verifyHostname="${zaakbrug.zgw.zaken-api.verifyHostname}"
                    allowSelfSignedCertificates="${zaakbrug.zgw.zaken-api.allowSelfSignedCertificates}"
                    disableCookies="${zaakbrug.zgw.zaken-api.disableCookies}"
                    ignoreCertificateExpiredException="${zaakbrug.zgw.zaken-api.ignoreCertificateExpiredException}"
                    truststore="${zaakbrug.zgw.zaken-api.truststore.uri}"
                    truststoreAuthAlias="${zaakbrug.zgw.zaken-api.truststore.authAlias}"
                    truststoreType="${zaakbrug.zgw.zaken-api.truststore.type}"
                    maxExecuteRetries="5"
				    />
                <Param name="url" sessionKey="uuid" xpathExpression="concat('${zaakbrug.zgw.zaken-api.root-url}', 'zaak_bijwerken/', /uuid/text())">
                    <Param name="uuid" sessionKey="uuid"/>
                </Param>
                <Param name="Accept-Crs" value="EPSG:4326" />
                <Param name="Content-Crs"  value="EPSG:4326" />
                <Param name="Authorization"  sessionKey="Authorization" />
                <Forward name="success" path="EXIT" />
                <Forward name="exception" path="ErrorJsonToXml" />
			</SenderPipe>

            <JsonPipe
                name="ErrorJsonToXml"
                >
                <Forward name="success" path="buildErrorMsg" />
            </JsonPipe>

            <XsltPipe
                name="buildErrorMsg"
                styleSheetName="Common/xsl/ParseNegativeHttpResult.xsl"
                >
                <Param name="senderPipeName" value="PostZgwRol" />
                <Forward name="success" path="EXCEPTION" />
            </XsltPipe>
        </Pipeline>
    </Adapter>
</Module>